{
  "expo": {
    "name": "ETH Wallet",
    "slug": "eth-wallet-dapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "scheme": "ethexam",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mjfernandez.ethwallet"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.mjfernandez.ethwallet"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
